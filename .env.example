# Bu dosyayı `.env` olarak kopyala; varsayılan değerlerle out-of-the-box çalışır.
# cp .env.example .env && docker compose up -d
# DSN şifresi MYSQL_PASSWORD ile AYNI olmalı.

MYSQL_DSN=trendyol:trendyol@tcp(mysql:3306)/trendyol?parseTime=true&charset=utf8mb4
JWT_SECRET=dev-secret-change-me

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_USER=trendyol
MYSQL_PASSWORD=trendyol

WEBHOOK_USERNAME=webhook
WEBHOOK_PASSWORD=webhook

LOG_LEVEL=info
TEST_MODE=true
PRINTER_DEVICE=output.txt

# role-based auth: "false" → login/JWT kapalı, doğrudan erişim. Set değilse açık (güvenli varsayılan).
RBAC_ENABLED=false

CF_TUNNEL_TOKEN=
